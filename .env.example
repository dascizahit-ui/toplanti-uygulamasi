# ============================================
# TOPLANTI UYGULAMASI - ORTAM DEĞİŞKENLERİ
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin
# cp .env.example .env

# ---------- GENEL ----------
APP_ADI=ToplantiUygulamasi
APP_SURUMU=1.0.0
ORTAM=gelistirme
DEBUG=true

# ---------- VERİTABANI (PostgreSQL) ----------
POSTGRES_SUNUCU=localhost
POSTGRES_PORT=5432
POSTGRES_KULLANICI=toplanti_admin
POSTGRES_SIFRE=guclu_sifre_123
POSTGRES_DB=toplanti_db
VERITABANI_URL=postgresql+asyncpg://toplanti_admin:guclu_sifre_123@localhost:5432/toplanti_db

# ---------- REDIS ----------
REDIS_SUNUCU=localhost
REDIS_PORT=6379
REDIS_SIFRE=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---------- JWT & GÜVENLİK ----------
JWT_GIZLI_ANAHTAR=buraya-cok-guclu-ve-uzun-bir-anahtar-yazin-en-az-32-karakter
JWT_ALGORITMA=HS256
ERISIM_TOKEN_SURESI_DAKIKA=30
YENILEME_TOKEN_SURESI_GUN=7

# ---------- CORS ----------
IZIN_VERILEN_KAYNAKLAR=http://localhost:3000,http://localhost:3001

# ---------- MEDIASOUP ----------
MEDIASOUP_DINLEME_IP=0.0.0.0
MEDIASOUP_DUYURULAN_IP=127.0.0.1
MEDIASOUP_PORT=3478
MEDIASOUP_WS_PORT=4443

# ---------- TURN/STUN ----------
TURN_SUNUCU=turn:localhost:3478
TURN_KULLANICI=toplanti_turn
TURN_SIFRE=turn_sifre_123
STUN_SUNUCU=stun:stun.l.google.com:19302

# ---------- BACKEND ----------
BACKEND_SUNUCU=0.0.0.0
BACKEND_PORT=8000
